 */
  public com.aspose.threed.Vector3 readVector3(int idx, com.aspose.threed.VertexField field);
/**
 * Read the vector3 field
 * @param idx The index of vertex to read
 * @param field The field with a Vector3/FVector3 data type
 */
  public com.aspose.threed.FVector3 readFVector3(int idx, com.aspose.threed.VertexField field);
/**
 * Read the vector2 field
 * @param idx The index of vertex to read
 * @param field The field with a Vector2/FVector2 data type
 * @return Vector2 of specified vertex's field
 */
  public com.aspose.threed.Vector2 readVector2(int idx, com.aspose.threed.VertexField field);
/**
 * Read the vector2 field
 * @param idx The index of vertex to read
 * @param field The field with a Vector2/FVector2 data type
 * @return FVector2 of specified vertex's field
 */
  public com.aspose.threed.FVector2 readFVector2(int idx, com.aspose.threed.VertexField field);
/**
 * Read the double field
 * @param idx The index of vertex to read
 * @param field The field with a float/double compatible data type
 * @return Double value of specified vertex's field
 */
  public double readDouble(int idx, com.aspose.threed.VertexField field);
