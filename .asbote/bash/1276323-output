  public float readFloat(int idx, com.aspose.threed.VertexField field);
/**
 * Write vertices data to the specified stream
 */
  public void writeVerticesTo(java.io.OutputStream stream) throws java.io.IOException;
/**
 * Write the indices data as 16bit integer to the stream
 */
